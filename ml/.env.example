# Anthropic API key — required for the /ai/chat clinical interpretation endpoint
# Get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# CORS — comma-separated list of allowed origins
# Local dev: leave as * (default in api.py)
# Production: set to your CloudFront or domain URL
# ALLOWED_ORIGINS=https://your-domain.com
